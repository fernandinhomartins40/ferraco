# ============================================================================
# FERRACO CRM - Evolution API Configuration
# ============================================================================
#
# Este arquivo contém as variáveis de ambiente para configurar a Evolution API
# para integração WhatsApp completa e profissional
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env na raiz do projeto
# 2. A API Key será gerada automaticamente se não for fornecida
# 3. Ajuste as configurações conforme necessário
#
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://ferraco:ferraco123@postgres:5432/ferraco_crm

# ============================================================================
# JWT
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================================================
# EVOLUTION API - WhatsApp Integration
# ============================================================================

# URL da Evolution API (não alterar se usando docker-compose)
EVOLUTION_API_URL=http://evolution-api:8080

# Nome da instância WhatsApp (personalizar se desejar)
EVOLUTION_INSTANCE_NAME=ferraco-crm

# API Key Evolution (deixe vazio para gerar automaticamente)
# Se fornecido, deve ser uma string aleatória segura
# Exemplo: openssl rand -hex 32
EVOLUTION_API_KEY=

# URL do backend (onde os webhooks serão recebidos)
BACKEND_URL=http://ferraco-crm-vps:3000

# ============================================================================
# SERVIDOR
# ============================================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
API_PREFIX=/api

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGIN=*
ALLOWED_ORIGINS=*

# ============================================================================
# FRONTEND URL (para WebSockets)
# ============================================================================
FRONTEND_URL=http://localhost:3000

# ============================================================================
# WHATSAPP SESSIONS
# ============================================================================
WHATSAPP_SESSIONS_PATH=/app/sessions

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. API Key Automática:
#    - Se EVOLUTION_API_KEY estiver vazio, será gerada automaticamente
#    - A mesma key deve ser usada no container evolution-api e no backend
#
# 2. Webhook URL:
#    - O backend expõe o endpoint: /webhooks/evolution
#    - Evolution API enviará eventos para: ${BACKEND_URL}/webhooks/evolution
#
# 3. Funcionalidades Disponíveis:
#    - Envio de mensagens (texto, imagem, vídeo, áudio, documento)
#    - Recebimento em tempo real via WebSocket
#    - Status de mensagens (✓, ✓✓, ✓✓ azul)
#    - QR Code automático
#    - Gerenciamento de conversas
#    - Gerenciamento de contatos
#    - Criação de grupos
#    - Presença (online, digitando, gravando)
#    - Atualização de perfil
#
# 4. Rotas API Disponíveis:
#    - GET  /api/evolution/status         - Status da conexão
#    - POST /api/evolution/connect        - Conectar WhatsApp
#    - POST /api/evolution/disconnect     - Desconectar
#    - POST /api/evolution/send/text      - Enviar texto
#    - POST /api/evolution/send/image     - Enviar imagem
#    - POST /api/evolution/send/video     - Enviar vídeo
#    - POST /api/evolution/send/audio     - Enviar áudio
#    - POST /api/evolution/send/file      - Enviar arquivo
#    - POST /api/evolution/send/location  - Enviar localização
#    - POST /api/evolution/send/contact   - Enviar contato
#    - GET  /api/evolution/chats          - Listar conversas
#    - GET  /api/evolution/messages/:id   - Listar mensagens
#    - GET  /api/evolution/contacts       - Listar contatos
#    - POST /api/evolution/presence       - Atualizar presença
#    - POST /api/evolution/group/create   - Criar grupo
#    - PUT  /api/evolution/profile/picture - Atualizar foto perfil
#    - PUT  /api/evolution/profile/name   - Atualizar nome perfil
#    - PUT  /api/evolution/profile/status - Atualizar status
#
# 5. Eventos WebSocket (frontend):
#    - whatsapp:qr                    - QR Code atualizado
#    - whatsapp:status                - Status de conexão
#    - whatsapp:message               - Nova mensagem
#    - whatsapp:message:ack           - Status de mensagem (✓✓)
#    - whatsapp:message:deleted       - Mensagem deletada
#    - whatsapp:presence              - Presença de contato
#    - whatsapp:group:participants    - Participantes de grupo
#
# ============================================================================
